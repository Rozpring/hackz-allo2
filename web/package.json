{
  "name": "table-bang-concentration",
  "version": "0.1.0",
  "description": "台パン神経衰弱 — 埋め込み可能な Web 版（Web Component）。サーバー不要のクライアントサイド完結。",
  "type": "module",
  "main": "dist/table-bang.js",
  "module": "dist/table-bang.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/table-bang.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:phone": "vite --host",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.18",
    "cannon-es": "^0.20.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
